# Copie ce fichier en .env et remplis les valeurs

# ── Sécurité (obligatoire en production) ──────────────────────────────────────
SECRET_KEY=change-moi-une-longue-chaine-aleatoire-min-50-chars
DEBUG=False
ALLOWED_HOSTS=ton-app.up.railway.app,www.ton-domaine.sn

# ── Base de données ───────────────────────────────────────────────────────────
# Production : PostgreSQL OBLIGATOIRE via DATABASE_URL.
#   Exemple Railway : postgresql://user:password@host:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Dev uniquement (si DATABASE_URL est vide) : nom du fichier SQLite.
DB_NAME=db.sqlite3

# ── CORS (frontend autorisé) ──────────────────────────────────────────────────
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://ton-app.netlify.app
CSRF_TRUSTED_ORIGINS=https://ton-app.netlify.app

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Cache / Rate-limit (obligatoire en production) ────────────────────────────
# django-ratelimit exige un cache atomique partagé entre les workers gunicorn.
# Exemple Railway : redis://default:password@host:6379
REDIS_URL=redis://localhost:6379

# ── Email SMTP ────────────────────────────────────────────────────────────────
EMAIL_HOST_USER=ton-email@gmail.com
EMAIL_HOST_PASSWORD=ton-app-password-gmail
