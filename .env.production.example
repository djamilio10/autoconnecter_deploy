# Copier en .env.production sur le VPS et remplir les valeurs manquantes.
# Ne JAMAIS committer le fichier .env.production rempli (voir .gitignore).

# ── Sécurité (obligatoire) ─────────────────────────────────────────────────
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=autoconnect.site,www.autoconnect.site

# ── Base de données (Postgres du docker-compose) ───────────────────────────
POSTGRES_DB=autoconnect
POSTGRES_USER=autoconnect
POSTGRES_PASSWORD=

# ── CORS / CSRF ─────────────────────────────────────────────────────────────
# Même domaine pour front et back (Caddy proxifie tout) : ces valeurs suffisent.
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://autoconnect.site,https://www.autoconnect.site
CSRF_TRUSTED_ORIGINS=https://autoconnect.site,https://www.autoconnect.site

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Email SMTP ──────────────────────────────────────────────────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── PayTech (clés de PRODUCTION, pas les clés de test) ──────────────────────
PAYTECH_API_KEY=
PAYTECH_SECRET_KEY=
PAYTECH_ENV=prod

# ── URLs publiques ────────────────────────────────────────────────────────
FRONTEND_URL=https://autoconnect.site
BACKEND_PUBLIC_URL=https://autoconnect.site
