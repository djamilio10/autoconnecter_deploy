# Copier en .env.production sur le VPS et remplir les valeurs manquantes.
# Ne JAMAIS committer le fichier .env.production rempli (voir .gitignore).

# ── Sécurité (obligatoire) ─────────────────────────────────────────────────
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=autoconnect.site,www.autoconnect.site

# ── Base de données (Postgres du docker-compose) ───────────────────────────
POSTGRES_DB=autoconnect
POSTGRES_USER=autoconnect
POSTGRES_PASSWORD=

# ── CORS / CSRF ─────────────────────────────────────────────────────────────
# Même domaine pour front et back (Caddy proxifie tout) : ces valeurs suffisent.
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://autoconnect.site,https://www.autoconnect.site
CSRF_TRUSTED_ORIGINS=https://autoconnect.site,https://www.autoconnect.site

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Email SMTP ──────────────────────────────────────────────────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── PayTech (clés de PRODUCTION, pas les clés de test) ──────────────────────
PAYTECH_API_KEY=
PAYTECH_SECRET_KEY=
PAYTECH_ENV=prod

# ── URLs publiques ────────────────────────────────────────────────────────
FRONTEND_URL=https://autoconnect.site
BACKEND_PUBLIC_URL=https://autoconnect.site

# ── Protection de l'admin Django (basic_auth Caddy) ────────────────────────
# Deuxième barrière devant /admin/, AVANT Django : les robots qui testent des
# mots de passe n'atteignent même plus l'application.
#
# ADMIN_USER          : l'identifiant de votre choix (≠ de votre login Django)
# ADMIN_PASSWORD_HASH : l'EMPREINTE du mot de passe, jamais le mot de passe.
#                       Générez-la sur le serveur avec :
#                         docker run --rm -it caddy:2-alpine caddy hash-password
#                       Caddy demande le mot de passe (saisie invisible) puis
#                       affiche une empreinte commençant par $2a$14$…
#                       Collez-la telle quelle ci-dessous, sans guillemets.
#
# ⚠️ Le dépôt Git est public : ces valeurs ne doivent vivre QUE dans
#    .env.production (ignoré par git), jamais dans le Caddyfile.
#    Choisissez un mot de passe long (une phrase de 4-5 mots).
ADMIN_USER=
ADMIN_PASSWORD_HASH=
